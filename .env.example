# One email for all polite pools (OpenAlex, Crossref, Unpaywall).
# Just your email address — no signup needed. Set this once and you're done.
SCHOLARK_CONTACT_EMAIL=

# Optional: Semantic Scholar API key for higher rate limits
# Get one at https://www.semanticscholar.org/product/api#api-key
SEMANTIC_SCHOLAR_API_KEY=

# Optional per-service overrides (each falls back to SCHOLARK_CONTACT_EMAIL)
OPENALEX_EMAIL=
CROSSREF_MAILTO=
UNPAYWALL_EMAIL=
