# Optional: Semantic Scholar API key for higher rate limits
# Get one at https://www.semanticscholar.org/product/api#api-key
SEMANTIC_SCHOLAR_API_KEY=

# Optional: email for OpenAlex polite pool (higher rate limits)
OPENALEX_EMAIL=

# Required for Unpaywall (find open access PDFs)
# Just use your email address — no signup needed
UNPAYWALL_EMAIL=
